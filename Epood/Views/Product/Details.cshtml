@model Epood.Models.Product

<h2>@Model.Name</h2>

<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" style="width:100%; max-height:400px; object-fit: cover;"/>
        }
        else
        {
            <p>No image</p>
        }
    </div>

    <div class="col-md-6">
        <h4>Description</h4>
        <p>@Model.Description</p>

        @if (Model.IsAuction)
        {
            <p><strong>Auction</strong></p>
            <p>Starting price: @Model.MinPrice €</p>
            <p>Ends: @Model.AuctionEndTime</p>
        }
        else
        {
            <p><strong>Price:</strong> @Model.Price €</p>
        }

        <br />

        <button class="btn btn-success">Add to cart</button>
    </div>
</div>